{
  "kind": "collectionType",
  "collectionName": "topics",
  "info": {
    "singularName": "topic",
    "pluralName": "topics",
    "displayName": "Topic",
    "description": "Forum discussion topics"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "creationDate": {
      "type": "datetime"
    },
    "isPinned": {
      "type": "boolean",
      "default": false
    },
    "views": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area"
    },
    "group": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::group.group"
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::post.post"
    }
  }
}