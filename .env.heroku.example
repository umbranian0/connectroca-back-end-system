# Heroku-only template for ConnectTroca Strapi backend.
# Set these values in Heroku config vars (`heroku config:set ...`).

NODE_ENV=production
HOST=0.0.0.0
IS_PROXIED=true
HEROKU_APP_NAME=your-heroku-app-name
PUBLIC_URL=https://your-heroku-app-name.herokuapp.com
ADMIN_URL=/admin

APP_KEYS=change-this-key-1,change-this-key-2,change-this-key-3,change-this-key-4
API_TOKEN_SALT=change-this-api-token-salt
ADMIN_JWT_SECRET=change-this-admin-jwt-secret
TRANSFER_TOKEN_SALT=change-this-transfer-token-salt
JWT_SECRET=change-this-jwt-secret
ENCRYPTION_KEY=change-this-encryption-key

ADMIN_ACCESS_TOKEN_LIFESPAN=1800
ADMIN_REFRESH_TOKEN_MAX_LIFESPAN=2592000
ADMIN_REFRESH_TOKEN_IDLE_LIFESPAN=1209600
ADMIN_SESSION_MAX_LIFESPAN=86400
ADMIN_SESSION_IDLE_LIFESPAN=7200
AUDIT_LOGS_ENABLED=true

DATABASE_CLIENT=postgres
# Heroku Postgres automatically sets DATABASE_URL.
DATABASE_URL=postgres://username:password@host:5432/database
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000

# Optional component-style vars. You can auto-fill these from DATABASE_URL with:
# npm run heroku:sync-db-vars -- <your-heroku-app-name>
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SCHEMA=public

API_DEFAULT_LIMIT=25
API_MAX_LIMIT=100
API_WITH_COUNT=true

CORS_ORIGIN=https://connectroca-front-end-system.vercel.app,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_DEVELOP_URL=https://connectroca-front-end-system.vercel.app
CORS_ALLOW_VERCEL_PREVIEWS=true
STRAPI_TELEMETRY_DISABLED=true

